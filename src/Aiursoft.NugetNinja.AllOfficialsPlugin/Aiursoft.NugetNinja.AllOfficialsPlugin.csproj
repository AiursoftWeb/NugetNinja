<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <Version>1.0.2</Version>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Aiursoft.NugetNinja.AllOfficialsPlugin</AssemblyName>
    <RootNamespace>Aiursoft.NugetNinja.AllOfficialsPlugin</RootNamespace>
